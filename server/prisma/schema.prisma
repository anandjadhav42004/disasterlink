generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SOSStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum SOSType {
  EARTHQUAKE
  FLOOD
  FIRE
  MEDICAL
  TRAPPED
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id               String       @id @default(uuid())
  name             String
  phone            String       @unique
  email            String       @unique
  password         String
  role             String       @default("citizen")
  status           String       @default("active")
  emailVerified    Boolean      @default(false)
  deactivatedAt    DateTime?
  emergencyContacts Json        @default("[]")
  medicalInfo      Json         @default("{}")
  preferences      Json         @default("{}")
  primaryRoleId    String?
  primaryRole      Role?        @relation("PrimaryRole", fields: [primaryRoleId], references: [id])
  fcmToken         String?
  latitude         Float?
  longitude        Float?
  district         String?
  state            String?
  country          String?      @default("India")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  refreshTokens    RefreshToken[]
  sosRequests      SOSRequest[]
  volunteerProfile Volunteer?
  roles            UserRole[]
  auditLogs        AuditLog[]
  activeSessions   ActiveSession[]
  passwordResetCodes PasswordResetCode[]
  contactInquiries ContactInquiry[]

  @@index([role])
  @@index([status])
  @@index([primaryRoleId])
  @@index([district])
  @@index([state])
  @@index([latitude, longitude])
}

model PasswordResetCode {
  id        String   @id @default(uuid())
  email     String
  codeHash  String
  tokenHash String?
  purpose   String   @default("password_reset")
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
  @@index([purpose])
}

model Role {
  id              String           @id @default(uuid())
  slug            String           @unique
  name            String
  description     String?
  hierarchyLevel  Int              @default(10)
  accessScope     String           @default("local")
  isSystem        Boolean          @default(false)
  isActive        Boolean          @default(true)
  modules         Json             @default("[]")
  dashboards      Json             @default("[]")
  crud            Json             @default("{}")
  geographicScope Json             @default("{}")
  featureAccess   Json             @default("[]")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  primaryUsers    User[]           @relation("PrimaryRole")
  users           UserRole[]
  permissions     RolePermission[]

  @@index([hierarchyLevel])
  @@index([accessScope])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  module      String
  action      String
  description String?
  isSystem    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@index([module])
}

model UserRole {
  id          String   @id @default(uuid())
  userId      String
  roleId      String
  district    String?
  state       String?
  country     String?  @default("India")
  assignedBy  String?
  assignedAt  DateTime @default(now())
  expiresAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([district])
  @@index([state])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      String?
  action    String
  module    String
  severity  String   @default("INFO")
  location  String?
  ip        String?
  device    String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([severity])
  @@index([createdAt])
}

model ActiveSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  ip           String?
  device       String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  expiresAt    DateTime

  @@index([userId])
  @@index([lastSeenAt])
}

model SOSRequest {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  type        SOSType
  description String?
  latitude    Float
  longitude   Float
  severity    Severity   @default(MEDIUM)
  status      SOSStatus  @default(PENDING)
  imageUrl    String?
  volunteer   Volunteer? @relation(fields: [volunteerId], references: [id])
  volunteerId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([userId])
  @@index([volunteerId])
  @@index([latitude, longitude])
}

model Volunteer {
  id                String       @id @default(uuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id])
  isAvailable       Boolean      @default(true)
  assignedRequests  SOSRequest[]
  createdAt         DateTime     @default(now())

  @@index([isAvailable])
}

model Shelter {
  id        String   @id @default(uuid())
  name      String
  latitude  Float
  longitude Float
  capacity  Int
  occupied  Int      @default(0)
  address   String?
  contact   String?
  district  String?
  state     String?
  resources Json     @default("{}")
  emergencyCapacity Boolean @default(false)
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude])
  @@index([district])
  @@index([status])
}

model Alert {
  id        String   @id @default(uuid())
  title     String
  message   String
  severity  Severity
  latitude  Float?
  longitude Float?
  radius    Float?
  district  String?
  state     String?
  channels  Json     @default("[]")
  status    String   @default("active")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  ticketId  String   @unique
  status    String   @default("open")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
